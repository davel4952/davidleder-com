---
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = '' } = Astro.props;

const navLinks = [
  { href: '/services',     label: 'Services'      },
  { href: '/work-with-me', label: 'Work With Me'   },
  { href: '/insights',     label: 'Insights'       },
  { href: '/about',        label: 'About'          },
  { href: '/contact',      label: 'Contact'        },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | David Leder</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <nav>
      <a href="/" class="nav-logo">David <span>Leder</span></a>
      <ul class="nav-links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={activeNav === link.label.toLowerCase().replace(/\s+/g, '-') ? 'active' : ''}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a href="/work-with-me" class="nav-cta">Book a Session</a>
        </li>
      </ul>
    </nav>

    <slot />

    <footer>
      <a href="/" class="footer-brand">David <span>Leder</span></a>
      <ul class="footer-links">
        <li><a href="/services">Services</a></li>
        <li><a href="/work-with-me">Work With Me</a></li>
        <li><a href="/insights">Insights</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="footer-contact">
        <a href="mailto:david@davidleder.com">david@davidleder.com</a><br />
        <a href="tel:4086668877">408.666.8877</a><br />
        <a href="https://davidleder.com">davidleder.com</a>
      </div>
    </footer>

  </body>
</html>
