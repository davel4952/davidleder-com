---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Strategic Leadership & Executive Advisory" activeNav="home">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="eyebrow">Executive Advisory &amp; Strategic Leadership</span>
      <h1>
        Clarity for Leaders<br />
        <em>Moving Fast</em>
      </h1>
      <p>
        I help senior executives, founders, and leadership teams cut through complexity,
        align around what matters, and move from uncertainty to decisive action.
      </p>
      <div class="hero-actions">
        <a href="/work-with-me" class="btn-primary">Book a Strategy Session</a>
        <a href="/services" class="btn-ghost">Explore Services</a>
      </div>
      <div class="hero-trust">
        <span>Trusted by leaders at</span>
        <div class="trust-logos">
          <span class="trust-item">Fortune 500</span>
          <span class="trust-dot">&middot;</span>
          <span class="trust-item">Series B&ndash;D</span>
          <span class="trust-dot">&middot;</span>
          <span class="trust-item">PE-Backed</span>
          <span class="trust-dot">&middot;</span>
          <span class="trust-item">Family Enterprise</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll-indicator" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- ABOUT SNIPPET -->
  <section class="about-snippet">
    <div class="about-snippet-inner">
      <div class="about-snippet-text">
        <span class="section-label">About David</span>
        <h2>A Partner in the Room When the Stakes Are High</h2>
        <p>
          With decades of experience advising C-suite leaders across industries, I bring
          a rare combination of strategic clarity, operational depth, and executive presence.
          I&rsquo;m not a consultant who hands you a deck and disappears &mdash; I&rsquo;m in it with you.
        </p>
        <p>
          Whether you&rsquo;re navigating a transition, scaling through ambiguity, or realigning
          your organization around a new vision, I help you think more clearly and act
          more decisively.
        </p>
        <a href="/about" class="btn-teal-outline">More About David</a>
      </div>
      <div class="about-snippet-visual">
        <div class="about-stat-card">
          <div class="stat">20+</div>
          <div class="stat-label">Years advising executives</div>
        </div>
        <div class="about-stat-card">
          <div class="stat">200+</div>
          <div class="stat-label">Engagements completed</div>
        </div>
        <div class="about-stat-card">
          <div class="stat">12</div>
          <div class="stat-label">Industries served</div>
        </div>
        <div class="about-stat-card accent">
          <div class="stat">95%</div>
          <div class="stat-label">Client retention rate</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="services-grid-section">
    <div class="services-grid-inner">
      <div class="services-grid-header">
        <span class="section-label">What I Do</span>
        <h2>Services Built for Executive Clarity</h2>
        <p>Every engagement is tailored. Here&rsquo;s where most leaders start.</p>
      </div>
      <div class="services-grid">
        <a href="/services#strategy" class="service-card">
          <div class="service-icon">&#9654;</div>
          <h3>Strategic Advisory</h3>
          <p>
            Ongoing partnership to sharpen strategy, challenge assumptions, and keep
            your organization oriented around what matters most.
          </p>
          <span class="service-link">Learn more &rarr;</span>
        </a>
        <a href="/services#executive" class="service-card">
          <div class="service-icon">&#9670;</div>
          <h3>Executive Coaching</h3>
          <p>
            One-on-one work focused on leadership presence, decision-making under
            pressure, and navigating complex organizational dynamics.
          </p>
          <span class="service-link">Learn more &rarr;</span>
        </a>
        <a href="/services#team" class="service-card">
          <div class="service-icon">&#9632;</div>
          <h3>Team Alignment</h3>
          <p>
            Facilitated offsites, working sessions, and frameworks that help leadership
            teams get aligned and stay aligned through change.
          </p>
          <span class="service-link">Learn more &rarr;</span>
        </a>
        <a href="/services#lunch" class="service-card">
          <div class="service-icon">&#9711;</div>
          <h3>Lunch &amp; Learns</h3>
          <p>
            Engaging half-day and full-day sessions for leadership teams on strategy,
            communication, and executive effectiveness.
          </p>
          <span class="service-link">Learn more &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <div class="cta-band">
    <div class="cta-band-inner">
      <span class="section-label">Ready to Begin?</span>
      <h2>Let&rsquo;s Find Clarity Together</h2>
      <p>
        Most leaders know something needs to change. The hard part is knowing where to start.
        A single conversation can change that.
      </p>
      <div class="btn-group">
        <a href="/work-with-me" class="btn-white">Book a Session</a>
        <a href="/contact" class="btn-ghost">Send a Message</a>
      </div>
    </div>
  </div>

</Layout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 60% 40%, rgba(42,127,127,0.18) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 20% 80%, rgba(42,127,127,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
    padding: 120px 48px 80px;
    text-align: center;
    animation: fadeUp 0.8s ease both;
  }

  .hero-inner .eyebrow {
    display: inline-block;
    margin-bottom: 24px;
    background: rgba(42,127,127,0.15);
    border: 1px solid rgba(58,159,159,0.3);
    padding: 6px 16px;
    border-radius: 100px;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    color: var(--teal-light);
    font-weight: 600;
    text-transform: uppercase;
  }

  .hero-inner h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 28px;
  }

  .hero-inner h1 em {
    font-style: italic;
    color: var(--teal-light);
  }

  .hero-inner > p {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.75;
    max-width: 580px;
    margin: 0 auto 40px;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .hero-trust {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .trust-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 10px;
    flex-wrap: wrap;
  }

  .trust-item {
    color: rgba(255,255,255,0.45);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .trust-dot {
    color: rgba(255,255,255,0.2);
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
  }

  .hero-scroll-indicator span {
    display: block;
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
    animation: pulse 2s ease-in-out infinite;
  }

  .about-snippet {
    padding: 100px 0;
    background: var(--off-white);
  }

  .about-snippet-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-snippet-text .section-label {
    display: block;
    margin-bottom: 16px;
  }

  .about-snippet-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--navy);
    line-height: 1.25;
    margin-bottom: 20px;
  }

  .about-snippet-text p {
    font-size: 1rem;
    color: var(--gray-dark);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .about-snippet-text .btn-teal-outline {
    margin-top: 8px;
  }

  .about-snippet-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .about-stat-card {
    background: var(--white);
    border: 1px solid rgba(30,58,95,0.08);
    border-radius: 12px;
    padding: 28px 24px;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .about-stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(30,58,95,0.1);
  }

  .about-stat-card.accent {
    background: var(--navy);
  }

  .about-stat-card.accent .stat {
    color: var(--white);
  }

  .about-stat-card.accent .stat-label {
    color: rgba(255,255,255,0.6);
  }

  .stat {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--navy);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--gray-mid);
    font-weight: 500;
    line-height: 1.4;
  }

  .services-grid-section {
    padding: 100px 0;
    background: var(--white);
  }

  .services-grid-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .services-grid-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 64px;
  }

  .services-grid-header .section-label {
    display: block;
    margin-bottom: 14px;
  }

  .services-grid-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--navy);
    line-height: 1.25;
    margin-bottom: 16px;
  }

  .services-grid-header p {
    font-size: 1rem;
    color: var(--gray-mid);
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .service-card {
    display: block;
    background: var(--off-white);
    border: 1px solid rgba(30,58,95,0.07);
    border-radius: 16px;
    padding: 40px 36px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(30,58,95,0.1);
    border-color: rgba(42,127,127,0.25);
  }

  .service-icon {
    font-size: 1.5rem;
    color: var(--teal);
    margin-bottom: 20px;
    display: block;
  }

  .service-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .service-card p {
    font-size: 0.95rem;
    color: var(--gray-dark);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .service-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--teal);
    letter-spacing: 0.02em;
  }
</style>
